generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OPERATIONS_SALES
  PM
  DEV_WEBFLOW
  DEV_WORDPRESS
}

enum ProjectType {
  WEBFLOW
  WORDPRESS
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum AccessLevel {
  VIEWER
  EDITOR
  ADMIN
}

model LeadStatus {
  id           String   @id @default(cuid())
  name         String   @unique
  color        String   @default("#6B7280")
  sort_order   Int      @default(0)
  is_active    Boolean  @default(true)
  is_system    Boolean  @default(false)
  funnel_stage String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  leads        Lead[]

  @@map("lead_statuses")
}

model LeadSource {
  id         String   @id @default(cuid())
  name       String   @unique
  sort_order Int      @default(0)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  leads      Lead[]

  @@map("lead_sources")
}

model LeadDirection {
  id         String   @id @default(cuid())
  name       String   @unique
  geo        String?
  method     String?
  tool       String?
  is_active  Boolean  @default(true)
  sort_order Int      @default(0)
  created_at DateTime @default(now())
  leads      Lead[]

  @@map("lead_directions")
}

enum FinanceType {
  INCOME
  EXPENSE
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  avatar_url    String?
  password_hash String
  role          Role     @default(OPERATIONS_SALES)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  managed_projects  Project[]       @relation("ProjectPM")
  dev_projects      Project[]       @relation("ProjectDev")
  project_members   ProjectMember[]
  assigned_tasks    Task[]          @relation("TaskAssignee")
  created_tasks     Task[]          @relation("TaskCreator")
  task_comments     TaskComment[]
  leads             Lead[]
  finance_records   FinanceRecord[]
  documents         Document[]
  ai_logs           AiLog[]

  @@map("users")
}

model Project {
  id         String        @id @default(cuid())
  name       String
  client     String
  type       ProjectType
  image_url  String?
  deadline   DateTime?
  progress   Int           @default(0)
  status     ProjectStatus @default(ACTIVE)
  pm_id      String?
  dev_id     String?
  created_at DateTime      @default(now())
  updated_at DateTime      @updatedAt

  pm              User?           @relation("ProjectPM", fields: [pm_id], references: [id])
  dev             User?           @relation("ProjectDev", fields: [dev_id], references: [id])
  members         ProjectMember[]
  tasks           Task[]
  finance_records FinanceRecord[]
  documents       Document[]

  @@map("projects")
}

model ProjectMember {
  project_id   String
  user_id      String
  access_level AccessLevel @default(VIEWER)
  created_at   DateTime    @default(now())

  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([project_id, user_id])
  @@map("project_members")
}

model Task {
  id          String     @id @default(cuid())
  title       String
  project_id  String
  assignee_id String?
  priority    Priority   @default(MEDIUM)
  status      TaskStatus @default(TODO)
  deadline    DateTime?
  created_by  String
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt

  project  Project       @relation(fields: [project_id], references: [id], onDelete: Cascade)
  assignee User?         @relation("TaskAssignee", fields: [assignee_id], references: [id])
  creator  User          @relation("TaskCreator", fields: [created_by], references: [id])
  comments TaskComment[]

  @@map("tasks")
}

model TaskComment {
  id         String   @id @default(cuid())
  task_id    String
  user_id    String
  body       String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  task Task @relation(fields: [task_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id])

  @@map("task_comments")
}

model Lead {
  id                String   @id @default(cuid())
  name              String
  status_id         String?
  source_id         String?
  direction_id      String?
  telegram_username String?
  amount            Float    @default(0)
  comment           String?
  owner_id          String
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  owner           User           @relation(fields: [owner_id], references: [id])
  status          LeadStatus?    @relation(fields: [status_id], references: [id])
  source          LeadSource?    @relation(fields: [source_id], references: [id])
  direction       LeadDirection? @relation(fields: [direction_id], references: [id])
  finance_records FinanceRecord[]

  @@map("leads")
}

model Document {
  id         String   @id @default(cuid())
  project_id String?
  title      String
  content    String
  type       String   @default("SPEC")
  created_by String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  project Project? @relation(fields: [project_id], references: [id], onDelete: SetNull)
  creator User     @relation(fields: [created_by], references: [id])

  @@map("documents")
}

model AiLog {
  id          String   @id @default(cuid())
  user_id     String
  feature     String
  tokens_used Int
  created_at  DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@map("ai_logs")
}

model FinanceRecord {
  id          String      @id @default(cuid())
  type        FinanceType
  project_id  String?
  lead_id     String?
  amount      Float
  date        DateTime
  category    String
  description String
  created_by  String
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt

  project Project? @relation(fields: [project_id], references: [id], onDelete: SetNull)
  lead    Lead?    @relation(fields: [lead_id], references: [id], onDelete: SetNull)
  creator User     @relation(fields: [created_by], references: [id])

  @@map("finance_records")
}
